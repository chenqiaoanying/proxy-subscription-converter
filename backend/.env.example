# Local development (SQLite — no server required):
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Production (Neon PostgreSQL — use pooled connection string):
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# GitHub OAuth — create an app at https://github.com/settings/developers
# Homepage: http://localhost:5173, Callback: http://localhost:5173/api/auth/callback
# (In dev, callback goes through Vite's /api proxy so session cookies share the SPA origin.)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 32+ random bytes (e.g. `python -c 'import secrets; print(secrets.token_urlsafe(32))'`)
SESSION_SECRET=

# Must match the callback URL registered in the GitHub OAuth App
OAUTH_REDIRECT_URL=http://localhost:5173/api/auth/callback

# Where users land after successful login
FRONTEND_URL=http://localhost:5173
