// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
  package = "prisma-client"
}

datasource db {
  // provider = "postgresql"
  // url      = env("DATABASE_URL")
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Subscription {
  name          String   @id
  url           String
  userAgent     String?
  dataUpload    BigInt?
  dataDownload  BigInt?
  dataTotal     BigInt?
  expireAt      BigInt?
  proxies       Proxy[]
  filters       Filter[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Proxy {
  id                Int           @id @default(autoincrement())
  tag               String        @unique
  type              String
  subscriptionName  String
  subscription      Subscription  @relation(fields: [subscriptionName], references: [name])
  raw               Json
}

model Filter {
  tag           String    @id
  subscriptions Subscription[]
  includeTypes  String?
  excludeTypes  String?
  excludeRegex  String?
  includeRegex  String?
  createdAt     DateTime  @default(now())
}
