// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
  package = "prisma-client"
}

datasource db {
  // provider = "postgresql"
  // url      = env("DATABASE_URL")
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Subscription {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  url           String
  userAgent     String?
  dataUpload    BigInt?
  dataDownload  BigInt?
  dataTotal     BigInt?
  expireAt      BigInt?
  proxies       Proxy[]
  filters       FilterOnSubscription[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Proxy {
  id                Int           @id @default(autoincrement())
  tag               String
  type              String
  subscriptionId    Int
  subscription      Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  raw               Json
}

model Filter {
  id                      Int       @id @default(autoincrement())
  tag                     String    @unique
  type                    String
  subscriptions     FilterOnSubscription[]
  generators      GeneratorOnFilter[]
  proxyTypeFilterMode     String
  proxyTypes              String?
  excludeRegex            String?
  includeRegex            String?
  createdAt               DateTime  @default(now())
}

model FilterOnSubscription {
  filterId        Int
  subscriptionId  Int
  filter          Filter       @relation(fields: [filterId], references: [id], onDelete: Cascade)
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  @@id([filterId, subscriptionId])
}

model GeneratorOnFilter {
  generatorId     Int
  filterId        Int
  generator       SubscriptionGenerator @relation(fields: [generatorId], references: [id], onDelete: Cascade)
  filter          Filter               @relation(fields: [filterId], references: [id], onDelete: Cascade)
  @@id([generatorId, filterId])
}

model SubscriptionGenerator {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  type          String
  content       Json?
  url           String?
  filters       GeneratorOnFilter[]
}
