{
    "subcriber": {
        "subscriptions": {
            "subscription1": {
                "url": "https://4gviet.com/api/v1/client/subscribe?token=xx",
                "tag": "airport1_tag", # optional, if set, generate an outbound group with this tag, and put the nodes in this subscription into this group
                "enabled": true, # optional, default is true, if set to false, this subscription will be ignored
                "user_agent": "clashmeta" # optional, if set, use this user agent to request the subscription url
            }
        },
        "filters": [
            {
                "tag": "filter1_tag", # required, the tag of outbound generated by this filter, if the tag is the same as a subscription tag, the nodes from that subscription will be put into this group
                "type": "selector|urltest", # required, the type of outbound generated by this filter
                "include": {
                    "pattern": "pattern", # optional, if set, only the nodes that match this pattern will be included in the match result
                    "proxy_type": ["vmess", "ss"], # optional, if set, only the nodes with these proxy types will be included in the match result
                    "regex": true|false, # optional, default is false, if set to true, the pattern will be treated as a regex pattern
                    "match_case": true|false # optional, default is false, if set to true, the pattern will be matched case sensitive
                    "match_whole_word": true|false # optional, default is false, if set to true, the pattern will be matched as a whole word
                },
                "exclude": {
                    "pattern": "pattern", # optional, if set, the nodes that match this pattern will be excluded from the match result
                    "proxy_type": ["vmess", "ss"], # optional, if set, the nodes with these proxy types will be excluded from the match result
                    "regex": true|false, # optional, default is false, if set to true, the pattern will be treated as a regex pattern
                    "match_case": true|false # optional, default is false, if set to true, the pattern will be matched case sensitive
                    "match_whole_word": true|false # optional, default is false, if set to true, the pattern will be matched as a whole word
                },
                "subscriptions": [
                    "subscription1",
                    "subscription2"
                ] # optional, if set, only the nodes from these subscriptions will be included in the match result
            }
        ]
    },
    "config_template": "link or singbox config content(json)"
}